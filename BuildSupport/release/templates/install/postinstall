#!/bin/zsh
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "${SCRIPT_DIR}/helper_common.sh"

if [[ ! -x "${INSTALL_PATH}" ]]; then
  echo "설치된 helper 바이너리를 찾지 못했습니다: ${INSTALL_PATH}"
  exit 1
fi

if [[ ! -f "${PLIST_PATH}" ]]; then
  echo "설치된 launchd plist를 찾지 못했습니다: ${PLIST_PATH}"
  exit 1
fi

mkdir -p "${LOG_DIR}"
chown root:wheel "${LOG_DIR}"
chmod 755 "${LOG_DIR}"

chown root:wheel "${INSTALL_PATH}" "${PLIST_PATH}"
chmod 755 "${INSTALL_PATH}"
chmod 644 "${PLIST_PATH}"

launchctl bootstrap system "${PLIST_PATH}"
launchctl kickstart -k "system/${SERVICE_NAME}"

echo "CellCap helper 설치 및 기동이 완료되었습니다."
